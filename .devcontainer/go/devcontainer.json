{
  "name": "go-dev",
  "image": "mcr.microsoft.com/devcontainers/go:1-trixie",
  "runArgs": ["--hostname=go-dev"],
  "features": {
    "../common-setup": {}
  },
  "postCreateCommand": "/usr/local/share/common-setup/post-create.sh",
  "postStartCommand": "tmux new-session -d -s main || true",
  "customizations": {
    "vscode": {
      "extensions": ["golang.go"]
    }
  }
}
