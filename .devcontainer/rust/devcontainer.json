{
  "name": "rust-dev",
  "image": "mcr.microsoft.com/devcontainers/rust:1-trixie",
  "runArgs": ["--hostname=rust-dev"],
  "features": {
    "../common-setup": {}
  },
  "postCreateCommand": "/usr/local/share/common-setup/post-create.sh",
  "postStartCommand": "tmux new-session -d -s main || true",
  "customizations": {
    "vscode": {
      "extensions": ["rust-lang.rust-analyzer"]
    }
  }
}
